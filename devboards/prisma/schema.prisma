// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Modelo de Usuario
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  image         String?
  role          String    @default("explorer") // "explorer" | "creator"
  bio           String?
  
  // Relaciones
  createdPins   Pin[]     @relation("CreatedPins")
  savedPins     SavedPin[]
  boards        Board[]
  likes         Like[]
  comments      Comment[]
  notifications Notification[]
  
  // Relaciones de seguimiento
  followers     Follow[]  @relation("Following")
  following     Follow[]  @relation("Followers")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Modelo de Pin
model Pin {
  id            String    @id @default(cuid())
  title         String
  description   String?   // Descripción técnica del pin
  imageUrl      String
  codeSnippet   String?   // Código compartido
  language      String?   // "css" | "html" | "javascript" | "typescript" | "react"
  tags          String?   // Tags separados por coma
  
  // Relación con el autor
  author        User      @relation("CreatedPins", fields: [authorId], references: [id], onDelete: Cascade)
  authorId      String
  
  // Usuarios que han guardado este pin
  savedBy       SavedPin[]
  
  // Tableros que contienen este pin
  boards        BoardPin[]
  
  // Likes y comentarios
  likes         Like[]
  comments      Comment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Tabla intermedia para pins guardados
model SavedPin {
  id        String   @id @default(cuid())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  pinId     String
  
  savedAt   DateTime @default(now())
  
  @@unique([userId, pinId])
}

// Modelo de Tablero
model Board {
  id          String     @id @default(cuid())
  name        String
  description String?
  isPrivate   Boolean    @default(false)
  
  // Relación con el propietario
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  // Pins en este tablero
  pins        BoardPin[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Tabla intermedia para pins en tableros
model BoardPin {
  id        String   @id @default(cuid())
  
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId   String
  
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  pinId     String
  
  addedAt   DateTime @default(now())
  
  @@unique([boardId, pinId])
}

// Modelo de Like
model Like {
  id        String   @id @default(cuid())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  pinId     String
  
  createdAt DateTime @default(now())
  
  @@unique([userId, pinId])
}

// Modelo de Comentario
model Comment {
  id        String   @id @default(cuid())
  content   String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  pin       Pin      @relation(fields: [pinId], references: [id], onDelete: Cascade)
  pinId     String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modelo de Seguimiento
model Follow {
  id          String   @id @default(cuid())
  
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  
  createdAt   DateTime @default(now())
  
  @@unique([followerId, followingId])
}

// Modelo de Notificación
model Notification {
  id        String   @id @default(cuid())
  type      String   // "new_pin" | "board_update"
  message   String
  read      Boolean  @default(false)
  
  // Usuario que recibe la notificación
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  // Referencias opcionales
  pinId     String?
  boardId   String?
  fromUserId String?
  
  createdAt DateTime @default(now())
}
